{
  "name": "@laflabs/lafetch",
  "version": "0.1.0-alpha.0",
  "description": "A DX-first, policy-composable TypeScript HTTP client built on Fetch.",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "private": true,
  "license": "UNLICENSED",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:worker": "vitest run tests/worker-runtime.test.ts",
    "test:next": "pnpm build && pnpm --filter @laflabs/lafetch-next-fixture build",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "check:runtimes": "pnpm test:browser && pnpm test:worker && pnpm test:next"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.10",
    "esbuild": "^0.28.1",
    "miniflare": "^4.20260710.0",
    "next": "^16.2.10",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
